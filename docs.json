{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Swish Docs",
  "colors": {
    "primary": "#121212",
    "light": "#fafafa",
    "dark": "#121212"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "getting-started"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/send",
              "features/request",
              "features/send-via-claim",
              "features/deposit",
              "features/withdraw",
              "features/export-wallet"
            ]
          },
          {
            "group": "Learn more",
            "pages": [
              "fees",
              "privacy-protocols",
              "privacy",
              "mobile",
              "faq"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
